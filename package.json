{
  "name": "uptime-kuma-api-ts",
  "version": "0.1.0",
  "description": "A TypeScript SDK for Uptime Kuma v2, built with Bun",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --packages external && tsc --project tsconfig.build.json",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration.test.ts",
    "check": "tsc --noEmit && biome check .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "kuma:start": "docker compose up -d && bun run setup-kuma",
    "kuma:stop": "docker compose down --volumes",
    "setup-kuma": "bun run scripts/setup-kuma-credentials.ts",
    "full-check": "biome check . && bun run build && bun run test:unit && bun run test:integration",
    "prepare": "husky",
    "prepublishOnly": "bun run lint && bun run test:unit && bun run build"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/bun": "^1.3.4",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "testcontainers": "^12.0.4",
    "typescript": "^7.0.2"
  },
  "optionalDependencies": {
    "@typescript/typescript-darwin-arm64": "7.0.2",
    "@typescript/typescript-darwin-x64": "7.0.2",
    "@typescript/typescript-linux-x64": "7.0.2",
    "@typescript/typescript-linux-arm64": "7.0.2",
    "@typescript/typescript-win32-x64": "7.0.2"
  },
  "peerDependencies": {
    "typescript": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "uptime-kuma",
    "monitoring",
    "sdk",
    "typescript",
    "bun",
    "socket-io",
    "api"
  ],
  "author": "Tulio Fernandes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuliof/uptime-kuma-api-ts.git"
  },
  "homepage": "https://github.com/tuliof/uptime-kuma-api-ts#readme",
  "bugs": {
    "url": "https://github.com/tuliof/uptime-kuma-api-ts/issues"
  }
}

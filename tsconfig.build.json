{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "types": ["bun"]
  },
  "include": ["src/**/*"],
  "exclude": ["tests/**/*", "**/*.test.ts", "**/*.spec.ts", "node_modules", "dist"]
}
